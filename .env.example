# EscalationSync – Environment Variables
# Copy this file to .env and fill in your secrets before running.
# NEVER commit .env to version control.

# ── Application ────────────────────────────────────────────────────────────────
APP_NAME=EscalationSync
APP_VERSION=1.0.0
ENVIRONMENT=development           # development | staging | production
LOG_LEVEL=INFO                    # DEBUG | INFO | WARNING | ERROR | CRITICAL

# ── API Server ─────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1                     # Increase in production (e.g. 4)

# ── LLM Provider Keys ──────────────────────────────────────────────────────────
GOOGLE_API_KEY=your_google_ai_studio_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Model Selection (optional overrides) ──────────────────────────────────────
TRIAGE_MODEL=gemini-1.5-flash
ESCALATION_MODEL=claude-3-5-sonnet-20241022
RESOLUTION_MODEL=gemini-1.5-flash

# ── Retry & Routing Tuning ─────────────────────────────────────────────────────
LLM_MAX_RETRIES=3
LLM_RETRY_WAIT_SECONDS=2.0
ESCALATION_CONFIDENCE_THRESHOLD=0.8

# ── Observability (Langfuse) ───────────────────────────────────────────────────
# Leave blank to disable tracing. Get keys from https://cloud.langfuse.com
LANGFUSE_SECRET_KEY=sk-lf-your_secret_key
LANGFUSE_PUBLIC_KEY=pk-lf-your_public_key
LANGFUSE_HOST=https://cloud.langfuse.com

# ── n8n Webhook Security (optional) ───────────────────────────────────────────
# If set, every inbound request must include X-N8N-Signature header
# containing the HMAC-SHA256 of the request body signed with this secret.
# Leave blank to disable signature verification (development only).
N8N_WEBHOOK_SECRET=
